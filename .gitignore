# Dependencies
node_modules/

# Build output
dist/

# Environment variables — never commit secrets
.env
.env.local
.env.*.local

# Vite cache
.vite/

# Sanity build-time fetch cache (KNOCH-042) — populated by
# scripts/render-projects.mjs when it successfully fetches
# galleryCollection from Sanity. Used as a fallback on subsequent
# builds if Sanity is unreachable. Local-only, regenerated.
.sanity-cache.json

# Editor / OS artifacts
.DS_Store
Thumbs.db
*.log

# Git internal (already tracked by git itself)
.git

# Claude Code local-only machine settings (not shared)
.claude/settings.local.json
# Agent scratch / memory directory — not project source
.claude/memories/

# Legacy / removed files
claude-code-setup-guide.md

# Terraform (from earlier project iteration)
.terraform
*.hcl
*.tfvars
*.lock
